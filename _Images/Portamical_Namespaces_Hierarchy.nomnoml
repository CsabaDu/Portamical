[<static>Converters]
[<abstract>TestBases]
[<abstract>TestBases.TestCaseDataCollection]
[<concrete>Attributes]
[<abstract>Assertions]

[
TestDataTypes
] <-- [
Converters
]

[
TestDataTypes
] <-- [
Attributes
]

[
Converters
] <-- [
TestBases
]

[
Converters
] <-- [
TestBases.TestCaseDataCollection
]
]



