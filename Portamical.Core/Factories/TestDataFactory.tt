        sb.AppendLine("    /// <param name=\"definition\">Description of the test scenario.</param>");
        sb.AppendLine("    /// <param name=\"expected\">Expected exception instance.</param>");
        for (int i = 1; i <= n; i++)
            sb.AppendLine($"    /// <param name=\"arg{i}\">The {Ordinals[i]} test argument value.</param>");
        sb.AppendLine($"    /// <returns>A new <see cref=\"TestDataThrows{{TException, {tp}}}\"/> instance.</returns>");
