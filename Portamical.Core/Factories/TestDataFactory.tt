        for (int i = 1; i <= n; i++)
            sb.AppendLine($"    /// <typeparam name=\"T{i}\">Type of the {Ordinals[i]} test argument.</typeparam>");
        sb.AppendLine("    /// <param name=\"definition\">Description of the test scenario.</param>");
